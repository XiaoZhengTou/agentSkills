{
  "name": "filesystem",
  "version": "1.0.0",
  "description": "文件系统 MCP Server，提供项目文件的读写操作能力",
  "command": "npx",
  "args": ["@modelcontextprotocol/server-filesystem", "./"],
  "permissions": {
    "read": ["**/*"],
    "write": ["src/**/*", "docs/**/*", "prisma/**/*"]
  },
  "tools": [
    "read_file",
    "write_file",
    "list_directory",
    "create_directory",
    "search_files"
  ]
}
